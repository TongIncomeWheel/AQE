//@version=6
indicator("Momentum Persistence v1.2", overlay=false)
// ============================================================================
// MOMENTUM PERSISTENCE v1.2 -- State-Based Colour
// CHANGE: Bar colour now reflects momentum STATE, not score level.
//   GREEN  = BUILDING (score rising AND below 75) -- entry zone
//   YELLOW = STRONG   (score rising AND >= 75)    -- hold, trail stops
//   RED    = FADING   (score declining)            -- no new entry
// Colour tells you what to do. No interpretation needed.
//
// All scoring logic unchanged from v1.1.
// Scale: 0-100. State determined by 3-bar rate of change on composite.
// ============================================================================

// SETTINGS
roc_period     = input.int(20, "ROC Period (days)", minval=10, maxval=40, group="Momentum", tooltip="Primary momentum measurement window. 20 = standard academic lookback.")
adx_period     = input.int(14, "ADX Period", minval=10, maxval=25, group="Momentum")
trend_ma       = input.int(50, "Trend MA Period", minval=20, maxval=100, group="Momentum", tooltip="MA for trend direction confirmation. 50 = standard.")
benchmark_sym  = input.symbol("SPY", "Benchmark", group="Relative")

// ==================== COMPONENT 1: ABSOLUTE MOMENTUM -- 30 pts ====================
// Rate of change vs its own history -- how strong is the current move relative to recent norms
roc_val = ta.roc(close, roc_period)
roc_sma = ta.sma(roc_val, 50)
roc_stdev = ta.stdev(roc_val, 50)
roc_zscore = roc_stdev != 0 ? (roc_val - roc_sma) / roc_stdev : 0

// Z-score > 1.0 = momentum significantly above normal
// Z-score 0-1.0 = positive but not exceptional
// Z-score < 0 = below average
abs_mom_score = roc_zscore >= 2.0 ? 30.0 : roc_zscore >= 1.5 ? 26.0 : roc_zscore >= 1.0 ? 22.0 : roc_zscore >= 0.5 ? 16.0 : roc_zscore >= 0.0 ? 10.0 : roc_zscore >= -0.5 ? 5.0 : 0.0

// ==================== COMPONENT 2: TREND PERSISTENCE (ADX) -- 25 pts ====================
// ADX measures trend strength regardless of direction
// High ADX = strong trend likely to persist
// Low ADX = choppy, momentum unreliable
[diplus, diminus, adx_val] = ta.dmi(adx_period, adx_period)

// Directional confirmation: DI+ must lead DI- for long momentum
di_bullish = diplus > diminus

adx_score = adx_val >= 40 and di_bullish ? 25.0 : adx_val >= 30 and di_bullish ? 22.0 : adx_val >= 25 and di_bullish ? 18.0 : adx_val >= 20 and di_bullish ? 12.0 : 0.0

// ==================== COMPONENT 3: RELATIVE MOMENTUM -- 25 pts ====================
// Stock's ROC vs benchmark ROC -- outperformance persistence
bench_close = request.security(benchmark_sym, timeframe.period, close)
stock_roc = ta.roc(close, roc_period)
bench_roc = ta.roc(bench_close, roc_period)
excess_return = stock_roc - bench_roc

// Excess return > 5% over 20 days = strong relative momentum
// This is the core factor the academic literature identifies
rel_mom_score = excess_return >= 15 ? 25.0 : excess_return >= 10 ? 22.0 : excess_return >= 5 ? 18.0 : excess_return >= 2 ? 13.0 : excess_return >= 0 ? 8.0 : excess_return >= -3 ? 3.0 : 0.0

// ==================== COMPONENT 4: TREND STRUCTURE -- 20 pts ====================
// Price above rising MAs = trend intact, momentum likely to persist
// Price below or MAs declining = trend broken, momentum fading
ma_50 = ta.sma(close, trend_ma)
ma_20 = ta.ema(close, 20)
ma_50_rising = ma_50 > ma_50[5]
ma_20_rising = ma_20 > ma_20[3]
price_above_50 = close > ma_50
price_above_20 = close > ma_20

// Stacking: price > 20MA > 50MA, both rising = strongest persistence
trend_score = price_above_20 and price_above_50 and ma_20_rising and ma_50_rising ? 20.0 : price_above_20 and price_above_50 and ma_50_rising ? 16.0 : price_above_50 and ma_50_rising ? 12.0 : price_above_50 ? 8.0 : price_above_20 ? 5.0 : 0.0

// ==================== COMPOSITE ====================
mp_raw = abs_mom_score + adx_score + rel_mom_score + trend_score
mp_score = math.max(math.min(mp_raw, 100), 0)

// ==================== VISUALIZATION ====================
// ==================== MOMENTUM STATE ====================
// 3-bar rate of change on composite determines state
mp_rising = mp_score > mp_score[3]
mp_state = mp_rising and mp_score < 75 ? 1 : mp_rising and mp_score >= 75 ? 2 : 3
// 1 = BUILDING (green), 2 = STRONG (yellow), 3 = FADING (red)

// Colour = state. No interpretation needed.
bar_color = mp_state == 1 ? color.new(color.green, 0) : mp_state == 2 ? color.new(color.yellow, 0) : color.new(color.red, 0)

plot(mp_score, "MP v1.2", color=bar_color, style=plot.style_histogram, linewidth=4)

hline(75, "Strong Zone", color=color.yellow, linestyle=hline.style_dotted)
hline(55, "Entry Floor", color=color.green, linestyle=hline.style_dotted)

bgcolor(mp_state == 1 ? color.new(color.green, 94) : mp_state == 3 ? color.new(color.red, 95) : na)

// ==================== TABLE ====================
var table t = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(t, 0, 0, "PERSISTENCE", bgcolor=color.new(color.teal, 30), text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "SCORE", bgcolor=color.new(color.teal, 30), text_color=color.white, text_size=size.small)

    color am_clr = abs_mom_score >= 22 ? color.lime : abs_mom_score >= 10 ? color.yellow : color.red
    table.cell(t, 0, 1, "Abs Momentum (30%)", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(abs_mom_score, "#") + "/30 | Z:" + str.tostring(roc_zscore, "#.#"), text_color=am_clr, text_size=size.small)

    color adx_clr = adx_score >= 18 ? color.lime : adx_score >= 12 ? color.yellow : color.red
    table.cell(t, 0, 2, "ADX Trend (25%)", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(adx_score, "#") + "/25 | ADX:" + str.tostring(adx_val, "#") + (di_bullish ? " DI+" : " DI-"), text_color=adx_clr, text_size=size.small)

    color rm_clr = rel_mom_score >= 18 ? color.lime : rel_mom_score >= 8 ? color.yellow : color.red
    table.cell(t, 0, 3, "Relative Mom (25%)", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(rel_mom_score, "#") + "/25 | +" + str.tostring(excess_return, "#.#") + "% vs SPY", text_color=rm_clr, text_size=size.small)

    color ts_clr = trend_score >= 16 ? color.lime : trend_score >= 8 ? color.yellow : color.red
    table.cell(t, 0, 4, "Trend Struct (20%)", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(trend_score, "#") + "/20 | " + (price_above_50 and ma_50_rising ? "STACKED" : price_above_50 ? "ABOVE" : "BELOW"), text_color=ts_clr, text_size=size.small)

    // State row
    string state_txt = mp_state == 1 ? "BUILDING" : mp_state == 2 ? "STRONG" : "FADING"
    color state_clr = mp_state == 1 ? color.green : mp_state == 2 ? color.yellow : color.red
    table.cell(t, 0, 5, "STATE", bgcolor=color.new(state_clr, 40), text_color=color.white, text_size=size.small)
    table.cell(t, 1, 5, state_txt, bgcolor=color.new(state_clr, 40), text_color=color.white, text_size=size.small)

    // Total
    table.cell(t, 0, 6, "MP TOTAL", bgcolor=color.new(state_clr, 20), text_color=color.white, text_size=size.small)
    table.cell(t, 1, 6, str.tostring(mp_score, "#") + "/100", bgcolor=color.new(state_clr, 20), text_color=color.white, text_size=size.normal)

// ==================== SCREENER EXPORTS ====================
plot(mp_score,         "MP_SCORE",     display=display.none)
plot(float(mp_state),  "MP_STATE",     display=display.none)
plot(abs_mom_score,    "MP_ABS_MOM",   display=display.none)
plot(adx_score,        "MP_ADX",       display=display.none)
plot(rel_mom_score,    "MP_REL_MOM",   display=display.none)
plot(trend_score,      "MP_TREND",     display=display.none)
plot(roc_zscore,       "MP_ROC_Z",     display=display.none)
plot(excess_return,    "MP_EXCESS_RET", display=display.none)

// ==================== ALERTS ====================
alertcondition(mp_state == 1 and mp_state[1] != 1, "MP Building", "Momentum now BUILDING -- entry zone")
alertcondition(mp_state == 2 and mp_state[1] != 2, "MP Strong", "Momentum now STRONG -- hold, trail stops")
alertcondition(mp_state == 3 and mp_state[1] != 3, "MP Fading", "Momentum now FADING -- no new entry")
alertcondition(adx_val >= 25 and adx_val[1] < 25, "ADX Strong Trend", "ADX crossed above 25 -- trend strength confirmed")
