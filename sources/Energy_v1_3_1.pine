//@version=6
indicator("Energy v1.3 (Aegis)", overlay=false)
// ============================================================================
// ENERGY v1.3 -- Synced to Scoring v1.5.3 (DSG-05 fix)
// "Is this stock coiled and ready?" -- volatility-structure readiness
//
// v1.3 FIX (DSG-05): VP Position now uses the SAME range-position proxy as the
//   Scoring overlay. ONE calculation, ONE number, everywhere. The real VP array
//   computation is RETAINED as diagnostic-only display (table rows show POC,
//   VAH/VAL) but does NOT feed the headline Energy score. This eliminates the
//   5-9pt delta between standalone and overlay (COP/ULS reference cases).
//
// KEPT: Real VP array as diagnostic display (standalone advantage for chart reading)
// CHANGED: VP scoring → range-position proxy matching overlay
// ============================================================================

// SETTINGS
vp_lookback = input.int(50, "VP Lookback", minval=30, maxval=100)
vp_rows     = input.int(24, "VP Rows", minval=15, maxval=40)
vol_period  = input.int(20, "Volume Period", minval=15, maxval=30)
atr_length  = input.int(20, "ATR Length", minval=15, maxval=30)
exh_trend_min = input.int(15, "Exhaustion Min Trend Bars", minval=5, maxval=40, tooltip="Deductions suppressed if uptrend < this. Early-trend volume is confirmation, not exhaustion.")

// ==================== COMPONENT 1: VP POSITION -- 17.5 pts ====================
// CANONICAL SCORING: Range-position proxy (matches Scoring overlay exactly)
en_hi50 = ta.highest(high, 50)
en_lo50 = ta.lowest(low, 50)
en_rng50 = en_hi50 - en_lo50
en_pos50 = en_rng50 != 0 ? (close - en_lo50) / en_rng50 * 100 : 50
en_psc = en_pos50 >= 90 ? 15.0 : en_pos50 >= 75 ? 17.0 : en_pos50 >= 60 ? 12.0 : en_pos50 >= 45 ? 8.0 : en_pos50 >= 30 ? 5.0 : 3.0
en_r5t = ta.highest(high, 5) - ta.lowest(low, 5)
en_atr_vp = ta.atr(20)
en_tt = en_pos50 > 75 and en_r5t < en_atr_vp * 2.0
en_lvn_proxy = en_tt ? 1.5 : 0.0
vp_position_score = math.min(en_psc + en_lvn_proxy, 17.5)

// DIAGNOSTIC ONLY: Real volume profile (array-based, barstate.islast)
// These values display in the table for chart reading but do NOT feed the score.
highest_vp = ta.highest(high, vp_lookback)
lowest_vp = ta.lowest(low, vp_lookback)
range_vp = highest_vp - lowest_vp
bucket_size = range_vp / vp_rows

var float[] bucket_volumes = array.new_float(vp_rows, 0.0)

if barstate.islast
    array.fill(bucket_volumes, 0.0)
    for i = 0 to vp_lookback - 1
        price_i = close[i]
        vol_i = volume[i]
        bucket_index = range_vp != 0 ? int((price_i - lowest_vp) / bucket_size) : 0
        bucket_index := math.max(0, math.min(bucket_index, vp_rows - 1))
        current_vol = array.get(bucket_volumes, bucket_index)
        array.set(bucket_volumes, bucket_index, current_vol + vol_i)

poc_index = 0
poc_volume = 0.0
if barstate.islast
    for i = 0 to vp_rows - 1
        vol = array.get(bucket_volumes, i)
        if vol > poc_volume
            poc_volume := vol
            poc_index := i

poc_price = lowest_vp + (poc_index * bucket_size) + (bucket_size / 2)

total_volume = 0.0
if barstate.islast
    for i = 0 to vp_rows - 1
        total_volume := total_volume + array.get(bucket_volumes, i)

target_volume = total_volume * 0.70
va_volume = array.get(bucket_volumes, poc_index)
va_high_idx = poc_index
va_low_idx = poc_index

if barstate.islast
    while va_volume < target_volume and (va_high_idx < vp_rows - 1 or va_low_idx > 0)
        vol_above = va_high_idx < vp_rows - 1 ? array.get(bucket_volumes, va_high_idx + 1) : 0.0
        vol_below = va_low_idx > 0 ? array.get(bucket_volumes, va_low_idx - 1) : 0.0
        if vol_above > vol_below and va_high_idx < vp_rows - 1
            va_high_idx := va_high_idx + 1
            va_volume := va_volume + vol_above
        else if va_low_idx > 0
            va_low_idx := va_low_idx - 1
            va_volume := va_volume + vol_below
        else
            break

vah_price = lowest_vp + (va_high_idx * bucket_size) + (bucket_size / 2)
val_price = lowest_vp + (va_low_idx * bucket_size) + (bucket_size / 2)

avg_bucket_vol = total_volume / vp_rows
current_bucket_idx = range_vp != 0 ? int((close - lowest_vp) / bucket_size) : 0
current_bucket_idx := math.max(0, math.min(current_bucket_idx, vp_rows - 1))

lvn_above = false
if barstate.islast and current_bucket_idx < vp_rows - 3
    low_vol_count = 0
    for i = current_bucket_idx + 1 to math.min(current_bucket_idx + 5, vp_rows - 1)
        if array.get(bucket_volumes, i) < avg_bucket_vol * 0.5
            low_vol_count := low_vol_count + 1
    lvn_above := low_vol_count >= 2

distance_to_poc = poc_price != 0 ? (close - poc_price) / poc_price * 100 : 0

poc_score = distance_to_poc >= 5 and distance_to_poc <= 15 ? 5.0 : math.abs(distance_to_poc) < 3 ? 3.0 : distance_to_poc >= 15 and distance_to_poc <= 30 ? 4.0 : distance_to_poc > 30 ? 2.0 : distance_to_poc < -3 and distance_to_poc >= -10 ? 3.0 : distance_to_poc < -10 ? 2.0 : 3.0

in_value_area = close >= val_price and close <= vah_price
above_vah = close > vah_price
distance_to_vah = vah_price != 0 ? (close - vah_price) / vah_price * 100 : 0

va_score = above_vah and distance_to_vah < 5 ? 6.0 : above_vah and distance_to_vah < 15 ? 5.0 : above_vah and distance_to_vah < 25 ? 3.5 : above_vah ? 1.5 : in_value_area ? 4.0 : close < val_price ? 2.0 : 3.0

lvn_score = lvn_above and above_vah ? 6.5 : lvn_above ? 4.5 : 2.5

vp_diag_score = poc_score + va_score + lvn_score  // Diagnostic only — NOT used in headline

// ==================== COMPONENT 2: PRICE ACTION -- 12.5 pts (with depth modifier) ====================
higher_lows_count = 0
for i = 1 to 4
    if low[i-1] > low[i]
        higher_lows_count := higher_lows_count + 1

structure_score = higher_lows_count >= 4 ? 5.0 : higher_lows_count >= 3 ? 4.0 : higher_lows_count >= 2 ? 3.0 : higher_lows_count >= 1 ? 1.5 : 0.0

range_5d = ta.highest(high, 5) - ta.lowest(low, 5)
range_20d = ta.highest(high, 20) - ta.lowest(low, 20)
compression_ratio = range_20d != 0 ? range_5d / range_20d : 1.0

tightness_base = compression_ratio < 0.3 ? 4.5 : compression_ratio < 0.5 ? 3.5 : compression_ratio < 0.7 ? 2.0 : compression_ratio < 0.9 ? 1.0 : 0.0

ema_20 = ta.ema(close, 20)
trending_up = close > ema_20 and close > close[5]
tightness_score = trending_up ? math.min(tightness_base + 1.5, 4.5) : tightness_base

recent_high = ta.highest(high, 20)
pullback_pct = recent_high != 0 ? (recent_high - close) / recent_high * 100 : 0
pullback_score = pullback_pct < 5 ? 3.0 : pullback_pct < 10 ? 2.5 : pullback_pct < 15 ? 2.0 : pullback_pct < 25 ? 1.0 : 0.0

pa_raw = structure_score + tightness_score + pullback_score
// Base depth modifier: en_pos50 already computed in VP Proxy block above
price_action_score = en_pos50 < 30 ? pa_raw * 0.5 : en_pos50 < 45 ? pa_raw * 0.7 : pa_raw

// ==================== COMPONENT 3: SQUEEZE -- 12.5 pts [FROM FLOW] ====================
en_bb = ta.sma(close, 20)
en_bd = 2.0 * ta.stdev(close, 20)
en_bu = en_bb + en_bd
en_bl = en_bb - en_bd
en_bw = en_bb != 0 ? (en_bu - en_bl) / en_bb * 100 : 0
en_bwl = ta.lowest(en_bw, 50)
en_bwh = ta.highest(en_bw, 50)
en_bwr = en_bwh - en_bwl
en_bwp = en_bwr != 0 ? (en_bw - en_bwl) / en_bwr * 100 : 50
en_kcr = ta.atr(20)
en_kcu = en_bb + en_kcr * 1.5
en_kcl = en_bb - en_kcr * 1.5
en_sq = en_bl > en_kcl and en_bu < en_kcu
squeeze_score = en_sq and en_bwp < 20 ? 12.5 : en_sq and en_bwp < 35 ? 10.0 : en_sq and en_bwp < 50 ? 7.5 : en_sq ? 5.0 : en_bwp < 30 ? 8.5 : en_bwp < 50 ? 4.0 : 0.0

// ==================== COMPONENT 4: EXHAUSTION -- 10 pts (with trend-duration gate) ====================
var int en_trend_bars = 0
en_trend_bars := close > ema_20 ? en_trend_bars + 1 : 0
en_trend_mature = en_trend_bars >= exh_trend_min

vol_avg_20 = ta.sma(volume, vol_period)
vol_ratio = vol_avg_20 != 0 ? volume / vol_avg_20 : 1.0
price_gain_pct = close[1] != 0 ? (close - close[1]) / close[1] * 100 : 0
climactic_penalty = vol_ratio > 3.0 and price_gain_pct < 2 ? -4.0 : vol_ratio > 2.5 and price_gain_pct < 3 ? -2.5 : 0.0

mfi_14 = ta.mfi(close, 14)
mfi_prev_high = ta.highest(mfi_14, 5)[1]
price_new_high = high == ta.highest(high, 10)
mfi_lower_high = mfi_14 < mfi_prev_high
macd_line = ta.ema(close, 12) - ta.ema(close, 26)
macd_prev_high = ta.highest(macd_line, 5)[1]
macd_lower_high = macd_line < macd_prev_high
divergence_penalty = price_new_high and mfi_lower_high ? -3.0 : price_new_high and macd_lower_high ? -2.0 : 0.0

bar_range = high - low
atr_val = ta.atr(atr_length)
bar_range_ratio = atr_val != 0 ? bar_range / atr_val : 1.0
follow_through_check = 0.0
if bar_range_ratio > 2.0
    follow_through_check := close[1] < close and high[1] < high ? 1.0 : 0.0
wide_spread_penalty = bar_range_ratio > 2.0 and vol_ratio > 2.0 and follow_through_check == 0 ? -3.0 : bar_range_ratio > 1.5 and vol_ratio > 1.5 ? -1.5 : 0.0

exhaustion_score = en_trend_mature ? math.max(10.0 + climactic_penalty + divergence_penalty + wide_spread_penalty, 0.0) : 10.0

// ==================== COMPONENT 5: ATR EXPANSION -- 7.0 pts (promoted from 5) ====================
atr_5d = ta.sma(atr_val, 5)
atr_20d = ta.sma(atr_val, 20)
atr_expansion_pct = atr_20d != 0 ? (atr_5d - atr_20d) / atr_20d * 100 : 0

atr_score = atr_expansion_pct >= 20 and atr_expansion_pct <= 80 ? 7.0 : atr_expansion_pct > 150 ? 2.0 : atr_expansion_pct > 80 ? 4.0 : atr_expansion_pct >= 15 ? 5.5 : atr_expansion_pct >= 10 ? 4.0 : atr_expansion_pct >= 0 ? 1.0 : atr_expansion_pct >= -10 ? 0.5 : 0.0

// ==================== FINAL SCORE ====================
// Raw max: 17.5 + 12.5 + 12.5 + 10 + 7 = 59.5
en_raw = vp_position_score + price_action_score + squeeze_score + exhaustion_score + atr_score
energy_100 = math.max(math.min(en_raw / 59.5 * 100.0, 100), 0)

// VISUALIZATION
bar_color = energy_100 >= 80 ? color.new(color.lime, 0) : energy_100 >= 64 ? color.new(color.green, 0) : energy_100 >= 50 ? color.new(color.yellow, 0) : color.new(color.red, 0)

plot(energy_100, "Energy v1.3", color=bar_color, style=plot.style_histogram, linewidth=4)
hline(80, "Strong", color=color.green, linestyle=hline.style_dotted)
hline(64, "Qualified", color=color.yellow, linestyle=hline.style_dotted)
hline(50, "Watch", color=color.orange, linestyle=hline.style_dashed)
bgcolor(energy_100 >= 80 ? color.new(color.green, 92) : energy_100 >= 64 ? color.new(color.yellow, 95) : color.new(color.red, 97))

// TABLE -- synced components + VP diagnostic detail
var table t = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 80))
if barstate.islast
    vp_pct = vp_position_score / 17.5 * 100
    vp_diag_pct = vp_diag_score / 17.5 * 100
    pa_pct = price_action_score / 12.5 * 100
    sq_pct = squeeze_score / 12.5 * 100
    exh_pct = exhaustion_score / 10.0 * 100
    atr_pct = atr_score / 7.0 * 100

    table.cell(t, 0, 0, "COMPONENT", bgcolor=color.purple, text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "%MAX", bgcolor=color.purple, text_color=color.white, text_size=size.small)

    table.cell(t, 0, 1, "VP Proxy", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(vp_pct, "#") + "%", text_color=vp_pct >= 70 ? color.lime : vp_pct >= 50 ? color.yellow : color.red, text_size=size.small)

    // DSG-05 diagnostic: show real VP score alongside proxy for delta verification
    vp_delta = math.abs(vp_pct - vp_diag_pct)
    table.cell(t, 0, 2, "VP Real (diag)", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 2, str.tostring(vp_diag_pct, "#") + "% Δ" + str.tostring(vp_delta, "#"), text_color=vp_delta < 10 ? color.silver : color.orange, text_size=size.tiny)

    table.cell(t, 0, 3, "Price Action", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(pa_pct, "#") + "%", text_color=pa_pct >= 70 ? color.lime : pa_pct >= 50 ? color.yellow : color.red, text_size=size.small)

    table.cell(t, 0, 4, "Squeeze", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(sq_pct, "#") + "%", text_color=sq_pct >= 80 ? color.lime : sq_pct >= 60 ? color.yellow : color.red, text_size=size.small)

    table.cell(t, 0, 5, "Exhaustion", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 5, str.tostring(exh_pct, "#") + "%", text_color=exh_pct >= 80 ? color.lime : exh_pct >= 60 ? color.yellow : color.red, text_size=size.small)

    table.cell(t, 0, 6, "ATR Expansion", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 6, str.tostring(atr_pct, "#") + "%", text_color=atr_pct >= 60 ? color.lime : atr_pct >= 40 ? color.yellow : color.red, text_size=size.small)

    // Diagnostic rows
    table.cell(t, 0, 7, "POC $", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 7, str.tostring(poc_price, "#.##"), text_color=color.silver, text_size=size.tiny)

    table.cell(t, 0, 8, "Trend Bars", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 8, str.tostring(en_trend_bars) + (en_trend_mature ? " MAT" : " YNG"), text_color=en_trend_mature ? color.lime : color.orange, text_size=size.tiny)

    table.cell(t, 0, 9, "ENERGY v1.3", bgcolor=bar_color, text_color=color.white, text_size=size.small)
    table.cell(t, 1, 9, str.tostring(energy_100, "#") + "/100", bgcolor=bar_color, text_color=color.white, text_size=size.small)

alertcondition(ta.crossover(energy_100, 80), "Energy Strong", "Energy >= 80")
alertcondition(ta.crossover(energy_100, 64), "Energy Qualified", "Energy >= 64")
alertcondition(exhaustion_score < 5 and en_trend_mature, "Exhaustion Warning", "Mature trend exhaustion detected")
