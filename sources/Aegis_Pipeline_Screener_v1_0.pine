//@version=6
indicator("Aegis Pipeline Screener v1.0", overlay=false, precision=1, max_bars_back=500)
// ============================================================================
// AEGIS PIPELINE SCREENER v1.0
// PURPOSE: Single-pass screener that ranks universe by momentum × quality.
//   Cuts a fat SC_MOMENTUM ≥ 65 pipeline down to the best-quality setups.
//
// OUTPUTS ONE NUMBER: PIPELINE_RANK (0–100)
//   = Momentum Component (70%) + FIP Path Quality (30%)
//
// Momentum Component: Simplified proxy for SC_MOMENTUM using daily data only.
//   NOT a replacement for Scoring v1.7 on the chart — this is the SCREENER
//   long-list filter. Candidates that pass the screener get full v1.7 analysis.
//
// FIP Component: Path smoothness (Gray & Vogel). SMOOTH paths rank higher
//   because steady accumulation persists; spike-driven momentum reverses.
//
// SCREENER COMPATIBLE: 0 request.security calls. Pure price/volume math.
//   All lookbacks ≤ 500 bars. Runs on any timeframe.
//
// USAGE:
//   1. Add to TradingView screener as a column
//   2. Filter: PIPELINE_RANK ≥ 60 (or your threshold)
//   3. Sort descending — top names are your refined pipeline
//   4. Run full Scoring v1.7 + committee on the top 10-15
//
// CHARTER REFERENCE: AIC v1.8 §9. Informational screener tool.
// ============================================================================

// ==================== INPUTS ====================

// Momentum
mom_lookback    = input.int(252, "Momentum Lookback", minval=63, maxval=500, group="Momentum", tooltip="Total return lookback in trading days")
mom_skip        = input.int(21, "Skip Recent Days", minval=0, maxval=42, group="Momentum", tooltip="Skip recent days to avoid short-term reversal")
rsi_len         = input.int(14, "RSI Length", group="Momentum")
adx_len         = input.int(14, "ADX Length", group="Momentum")
vol_sma_len     = input.int(50, "Volume SMA Length", group="Momentum")

// FIP
fip_lookback    = input.int(252, "FIP Lookback", minval=63, maxval=500, group="FIP")

// Weights
w_momentum      = input.float(0.70, "Momentum Weight", minval=0.0, maxval=1.0, step=0.05, group="Weights", tooltip="Weight for momentum component in PIPELINE_RANK")
w_fip           = input.float(0.30, "FIP Weight", minval=0.0, maxval=1.0, step=0.05, group="Weights", tooltip="Weight for FIP quality component")

// Display
show_table      = input.bool(true, "Show Dashboard", group="Display")
show_components = input.bool(true, "Show Component Histogram", group="Display")
tbl_pos         = input.string("Top Right", "Table Position", options=["Top Left", "Top Center", "Top Right", "Middle Right", "Bottom Right"], group="Display")

// ==================== MOMENTUM COMPONENT (0-100) ====================
// Simplified proxy for SC_MOMENTUM. Captures the core signals without
// the full 5-engine scoring suite. Designed for screener speed.

// --- 1. Price Momentum (0-30 pts) ---
// 12M return, skip 1M. The canonical momentum signal.
float mom_price_end = close[mom_skip]
float mom_price_start = close[mom_lookback]
float mom_return = not na(mom_price_end) and not na(mom_price_start) and mom_price_start > 0 ?
     (mom_price_end - mom_price_start) / mom_price_start * 100 : 0.0

// Normalise: 0% = 0pts, 50% = 15pts, 100%+ = 30pts
float mom_score = math.max(math.min(mom_return / 100 * 30, 30), 0)

// --- 2. Trend Strength (0-20 pts) ---
// ADX measures trend strength regardless of direction
// DMI calculation (Wilder's smoothing)
float tr = math.max(high - low, math.max(math.abs(high - close[1]), math.abs(low - close[1])))
float plus_dm = high - high[1] > low[1] - low ? math.max(high - high[1], 0) : 0
float minus_dm = low[1] - low > high - high[1] ? math.max(low[1] - low, 0) : 0

float atr_adx = ta.rma(tr, adx_len)
float plus_di = 100 * ta.rma(plus_dm, adx_len) / atr_adx
float minus_di = 100 * ta.rma(minus_dm, adx_len) / atr_adx
float dx = math.abs(plus_di - minus_di) / (plus_di + minus_di) * 100
float adx = ta.rma(dx, adx_len)

// ADX > 25 = trending. Bonus if +DI > -DI (bullish trend)
float trend_raw = adx > 40 ? 20 : adx > 30 ? 15 : adx > 25 ? 10 : adx > 20 ? 5 : 0
// Directional bonus: +DI dominating = bullish trend
float dir_bonus = plus_di > minus_di ? math.min((plus_di - minus_di) / 10, 5) : -5
float trend_score = math.max(math.min(trend_raw + dir_bonus, 20), 0)

// --- 3. RSI Momentum Zone (0-15 pts) ---
// RSI 50-70 = healthy momentum. >70 = extended. <50 = weak.
float rsi = ta.rsi(close, rsi_len)
float rsi_score = rsi >= 55 and rsi <= 75 ? 15 :
                  rsi > 75 ? 10 :  // Extended but still bullish
                  rsi >= 50 and rsi < 55 ? 8 :
                  rsi >= 45 and rsi < 50 ? 3 : 0

// --- 4. Volume Confirmation (0-15 pts) ---
// Recent volume above average = institutional participation
float vol_sma = ta.sma(volume, vol_sma_len)
float vol_ratio = vol_sma > 0 ? volume / vol_sma : 1.0
float vol_10d_avg = ta.sma(volume, 10)
float vol_trend = vol_sma > 0 ? vol_10d_avg / vol_sma : 1.0

// Rising volume on up days = accumulation
float vol_score = vol_trend > 1.3 ? 15 : vol_trend > 1.1 ? 10 : vol_trend > 0.9 ? 5 : 0

// --- 5. Moving Average Structure (0-20 pts) ---
// Price above key MAs = trend intact. MA stack = strong structure.
float ema20 = ta.ema(close, 20)
float sma50 = ta.sma(close, 50)
float sma150 = ta.sma(close, 150)
float sma200 = ta.sma(close, 200)

bool above_20 = close > ema20
bool above_50 = close > sma50
bool above_150 = close > sma150
bool above_200 = close > sma200
bool ma_stack = ema20 > sma50 and sma50 > sma150  // Bullish alignment
bool sma50_rising = sma50 > sma50[10]

float ma_score = 0.0
ma_score += above_20 ? 4 : 0
ma_score += above_50 ? 4 : 0
ma_score += above_150 ? 3 : 0
ma_score += above_200 ? 3 : 0
ma_score += ma_stack ? 3 : 0
ma_score += sma50_rising ? 3 : 0

// --- COMPOSITE MOMENTUM (0-100) ---
float raw_momentum = mom_score + trend_score + rsi_score + vol_score + ma_score
float momentum_component = math.min(raw_momentum, 100)

// ==================== FIP COMPONENT (0-100) ====================
// Frog-in-the-Pan: path smoothness. Higher = smoother = better.

float daily_ret = (close - close[1]) / close[1]

int pos_count = 0
int neg_count = 0
for i = 0 to fip_lookback - 1
    if not na(daily_ret[i])
        if daily_ret[i] > 0
            pos_count += 1
        else if daily_ret[i] < 0
            neg_count += 1

float pct_pos = fip_lookback > 0 ? pos_count / float(fip_lookback) : 0.5
float pct_neg = fip_lookback > 0 ? neg_count / float(fip_lookback) : 0.5

// Momentum sign (for FIP direction)
float cum_mom = not na(mom_price_end) and not na(mom_price_start) and mom_price_start > 0 ?
     (mom_price_end - mom_price_start) / mom_price_start : 0.0
float mom_sign = cum_mom >= 0 ? 1.0 : -1.0

float fip_score_raw = (pct_neg - pct_pos) * mom_sign
// FIP ranges roughly -0.30 (very smooth) to +0.20 (very jumpy)
// Map to 0-100: -0.30 → 100, 0.00 → 40, +0.20 → 0
float fip_clamped = math.max(math.min(fip_score_raw, 0.20), -0.30)
float fip_path_quality = ((0.20 - fip_clamped) / 0.50) * 100

// Spike detection penalty
float max_5d_ret = 0.0
for i = 0 to 4
    if not na(daily_ret[i])
        max_5d_ret := math.max(max_5d_ret, math.abs(daily_ret[i]) * 100)
bool spike_flag = max_5d_ret > 8.0
fip_path_quality := spike_flag ? math.max(fip_path_quality - 30, 0) : fip_path_quality

// FIP classification
int fip_class = fip_score_raw < -0.10 ? 1 : fip_score_raw <= 0.00 ? 0 : -1
string fip_label = fip_class == 1 ? "SMOOTH" : fip_class == 0 ? "MODERATE" : "JUMPY"
color fip_color = fip_class == 1 ? color.new(#00CC66, 0) : fip_class == 0 ? color.new(#FFAA00, 0) : color.new(#FF4444, 0)

// ==================== PIPELINE RANK (0-100) ====================

float pipeline_rank = momentum_component * w_momentum + fip_path_quality * w_fip

// Classification
string rank_class = pipeline_rank >= 75 ? "A — TOP TIER" :
                    pipeline_rank >= 60 ? "B — STRONG" :
                    pipeline_rank >= 45 ? "C — WATCH" : "D — SKIP"
color rank_color = pipeline_rank >= 75 ? color.new(#00FF88, 0) :
                   pipeline_rank >= 60 ? color.new(#00CC66, 0) :
                   pipeline_rank >= 45 ? color.new(#FFAA00, 0) : color.new(#FF4444, 0)

// ==================== VISUALISATION ====================

// Main histogram: PIPELINE_RANK
plot(show_components ? pipeline_rank : na, "Pipeline Rank", style=plot.style_columns,
     color=rank_color, linewidth=2)

// Component lines (overlay on histogram)
plot(show_components ? momentum_component : na, "Momentum", color=color.new(color.blue, 30), linewidth=1)
plot(show_components ? fip_path_quality : na, "FIP Quality", color=color.new(color.teal, 30), linewidth=1)

// Threshold lines
h75 = hline(75, "A Tier", color=color.new(color.green, 70), linestyle=hline.style_dashed)
h60 = hline(60, "B Tier", color=color.new(color.yellow, 70), linestyle=hline.style_dashed)
h45 = hline(45, "C Tier", color=color.new(color.orange, 70), linestyle=hline.style_dashed)

// ==================== DASHBOARD ====================

var pos = tbl_pos == "Top Left" ? position.top_left : tbl_pos == "Top Center" ? position.top_center : tbl_pos == "Top Right" ? position.top_right : tbl_pos == "Middle Right" ? position.middle_right : position.bottom_right

var table tbl = table.new(pos, 3, 9, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast and show_table
    // Header
    table.cell(tbl, 0, 0, "PIPELINE SCREENER", bgcolor=color.new(#1a2744, 30), text_color=color.white, text_size=size.normal)
    table.cell(tbl, 1, 0, "v1.0", bgcolor=color.new(#1a2744, 30), text_color=color.white, text_size=size.normal)
    table.cell(tbl, 2, 0, rank_class, bgcolor=color.new(#1a2744, 30), text_color=rank_color, text_size=size.normal)

    // Row 1: PIPELINE RANK
    table.cell(tbl, 0, 1, "RANK", text_color=color.gray, text_size=size.normal)
    table.cell(tbl, 1, 1, str.tostring(pipeline_rank, "#.1"), text_color=rank_color, text_size=size.large)
    table.cell(tbl, 2, 1, "/100", text_color=color.gray, text_size=size.normal)

    // Row 2: Momentum component
    color mom_clr = momentum_component >= 65 ? color.lime : momentum_component >= 50 ? color.yellow : color.red
    table.cell(tbl, 0, 2, "Momentum", text_color=color.gray, text_size=size.normal)
    table.cell(tbl, 1, 2, str.tostring(momentum_component, "#.1"), text_color=mom_clr, text_size=size.normal)
    table.cell(tbl, 2, 2, "× " + str.tostring(w_momentum * 100, "#") + "%", text_color=color.gray, text_size=size.small)

    // Row 3: FIP component
    table.cell(tbl, 0, 3, "Path Quality", text_color=color.gray, text_size=size.normal)
    table.cell(tbl, 1, 3, str.tostring(fip_path_quality, "#.1"), text_color=fip_color, text_size=size.normal)
    table.cell(tbl, 2, 3, fip_label + " × " + str.tostring(w_fip * 100, "#") + "%", text_color=fip_color, text_size=size.small)

    // Row 4: 12M Return
    color ret_clr = mom_return > 0 ? color.green : color.red
    table.cell(tbl, 0, 4, "12M Return", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 4, str.tostring(mom_return, "#.1") + "%", text_color=ret_clr, text_size=size.small)
    table.cell(tbl, 2, 4, str.tostring(mom_score, "#.0") + "/30", text_color=color.gray, text_size=size.small)

    // Row 5: Trend (ADX)
    table.cell(tbl, 0, 5, "Trend/ADX", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 5, str.tostring(adx, "#.1"), text_color=adx > 25 ? color.green : color.orange, text_size=size.small)
    table.cell(tbl, 2, 5, str.tostring(trend_score, "#.0") + "/20", text_color=color.gray, text_size=size.small)

    // Row 6: RSI
    table.cell(tbl, 0, 6, "RSI", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 6, str.tostring(rsi, "#.1"), text_color=rsi >= 50 and rsi <= 75 ? color.green : color.orange, text_size=size.small)
    table.cell(tbl, 2, 6, str.tostring(rsi_score, "#.0") + "/15", text_color=color.gray, text_size=size.small)

    // Row 7: MA Structure
    string ma_text = (above_20 ? "20" : "") + (above_50 ? " 50" : "") + (above_150 ? " 150" : "") + (above_200 ? " 200" : "")
    table.cell(tbl, 0, 7, "Above MAs", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 7, ma_text, text_color=ma_stack ? color.green : color.orange, text_size=size.small)
    table.cell(tbl, 2, 7, str.tostring(ma_score, "#.0") + "/20", text_color=color.gray, text_size=size.small)

    // Row 8: Spike flag
    table.cell(tbl, 0, 8, "Spike", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 8, spike_flag ? "⚠ " + str.tostring(max_5d_ret, "#.1") + "%" : "CLEAR", text_color=spike_flag ? color.red : color.green, text_size=size.small)
    table.cell(tbl, 2, 8, str.tostring(pos_count) + "↑ " + str.tostring(neg_count) + "↓", text_color=color.gray, text_size=size.small)

// ==================== SCREENER EXPORTS ====================
// These are the values available in TradingView screener columns.
// Sort by PIPELINE_RANK descending for best candidates.

plot(pipeline_rank,       "PIPE_RANK",     display=display.none)  // THE sort key
plot(momentum_component,  "PIPE_MOM",      display=display.none)  // Momentum sub-score
plot(fip_path_quality,    "PIPE_FIP",      display=display.none)  // Path quality sub-score
plot(fip_score_raw,       "PIPE_FIP_RAW",  display=display.none)  // Raw FIP for analysis
plot(float(fip_class),    "PIPE_FIP_CLASS", display=display.none) // 1=SMOOTH, 0=MOD, -1=JUMPY
plot(mom_return,          "PIPE_MOM_12M",  display=display.none)  // 12M return %
plot(adx,                 "PIPE_ADX",      display=display.none)  // ADX trend strength
plot(rsi,                 "PIPE_RSI",      display=display.none)  // RSI
plot(ma_score,            "PIPE_MA",       display=display.none)  // MA structure score
plot(spike_flag ? 1 : 0,  "PIPE_SPIKE",   display=display.none)  // Spike flag

// ==================== ALERTS ====================
alertcondition(pipeline_rank >= 75 and pipeline_rank[1] < 75, "A-Tier Entry", "Pipeline Rank crossed above 75 — top tier candidate")
alertcondition(pipeline_rank >= 60 and pipeline_rank[1] < 60, "B-Tier Entry", "Pipeline Rank crossed above 60 — strong candidate")
alertcondition(spike_flag and not spike_flag[1], "Spike Warning", "5-day spike detected — lottery-stock risk")
