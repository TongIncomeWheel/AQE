//@version=6
indicator("Flow v1.3 (Aegis)", overlay=false)
// Synced to Scoring v1.5.2 -- see Standalone_Drift_Analysis.md for change log
// REMOVED: Squeeze (->Energy), Liquidity (duplicate), Momentum multiplier (cliff)
// ADDED: Volume Skew (from Energy). CHANGED: Accum 10/20, HA +6 max, cap 17
// SCR-03 FIX: ta.cum replaced with math.sum(60) for screener parity.

flow_length = input.int(10, "Flow Period", minval=8, maxval=15)
ha_lookback = input.int(10, "HA Lookback", minval=8, maxval=15)
vol_period = input.int(20, "Volume Period", minval=15, maxval=30)

// COMPONENT 1: INSTITUTIONAL FLOW -- 17 pts max
mfi_sum_upper = 0.0
mfi_sum_lower = 0.0
for i = 0 to flow_length - 1
    p = hlc3[i] - hlc3[i+1]
    v = volume[i]
    if p > 0
        mfi_sum_upper := mfi_sum_upper + v * hlc3[i]
    else
        mfi_sum_lower := mfi_sum_lower + v * hlc3[i]
mfi = mfi_sum_lower != 0 ? 100.0 - (100.0 / (1.0 + mfi_sum_upper / mfi_sum_lower)) : 50.0
cmf_mfv = 0.0
cmf_vol = 0.0
for i = 0 to flow_length - 1
    r = high[i] - low[i]
    if r != 0
        cmf_mfv := cmf_mfv + (((close[i]-low[i])-(high[i]-close[i]))/r * volume[i])
        cmf_vol := cmf_vol + volume[i]
cmf = cmf_vol != 0 ? cmf_mfv / cmf_vol : 0
fl_fb = mfi > 55 and cmf > 0.05 ? 11.0 : mfi > 48 and cmf > 0.02 ? 8.0 : mfi > 42 and cmf > 0 ? 5.0 : mfi > 38 or cmf > -0.05 ? 2.5 : 0.0
atr_v = ta.atr(20)
hac = 0
for i = 0 to ha_lookback - 1
    hc = (open[i]+high[i]+low[i]+close[i])/4
    ho = i==0 ? (open+close)/2 : (open[i+1]+close[i+1])/2
    if math.abs(hc - ho) < atr_v * 0.5
        hac := hac + 1
ha_b = hac >= 5 ? 6.0 : hac >= 3 ? 4.0 : hac >= 2 ? 2.0 : 0.0
flow_score = math.min(fl_fb + ha_b, 17.0)

// COMPONENT 2: ACCUMULATION -- 7.5 pts max (lookback 10/20)
// SCR-03 FIX: ta.cum replaced with math.sum(60). ta.cum accumulates from bar zero —
//   chart (~5000 bars) and screener (~200 bars) produce different absolute A/D values,
//   causing linreg divergence. 60-bar rolling sum is screener-safe.
ad_raw = close==high and close==low or high==low ? 0.0 : ((2*close-low-high)/(high-low))*volume
ad = math.sum(ad_raw, 60)
ad_s = ta.linreg(ad, 10, 0)
ad_l = ta.linreg(ad, 20, 0)
accum_score = ad_l != 0 and ad_s > ad_l*1.1 ? 7.5 : ad_l != 0 and ad_s > ad_l ? 5.5 : ad_l != 0 and ad_s > ad_l*0.85 ? 3.0 : ad_s > 0 ? 1.5 : 0.0

// COMPONENT 3: VOLUME TREND -- 7.5 pts max
v5 = ta.sma(volume,5)
v20 = ta.sma(volume,vol_period)
vtr = v20 != 0 ? v5/v20 : 1.0
spk = v20 != 0 ? volume/v20 : 1.0
spk_b = spk > 2.0 ? 2.0 : spk > 1.5 ? 1.0 : 0.0
vt_b = vtr > 1.2 ? 5.5 : vtr > 1.05 ? 4.0 : vtr > 0.9 ? 2.0 : 0.0
volume_score = math.min(vt_b + spk_b, 7.5)

// COMPONENT 4: VOLUME SKEW -- 3.5 pts max [FROM ENERGY]
uv = 0.0
dv = 0.0
for i = 0 to 9
    if close[i] > close[i+1]
        uv := uv + volume[i]
    else
        dv := dv + volume[i]
udr = dv != 0 ? uv/dv : 1.0
skew_score = udr > 1.5 ? 3.5 : udr > 1.2 ? 2.5 : udr >= 0.8 ? 1.5 : 0.0

// EXTENSION -- +5 to -8
h20 = ta.highest(high,20)
h20p = ta.highest(high[1],20)
is_nh = high >= h20p
l20 = ta.lowest(low,20)
rng = h20 - l20
pp = rng != 0 ? (close-l20)/rng*100 : 50
ema20 = ta.ema(close,20)
de = ema20 != 0 ? (close-ema20)/ema20*100 : 0
cr = (high-low) != 0 ? (close-low)/(high-low) : 0.5
vr = v20 != 0 ? volume/v20 : 1.0
r5 = ta.highest(high,5)-ta.lowest(low,5)
tra = ta.sma(ta.tr,20)
ra20 = tra*5
isc = ra20 != 0 ? r5/ra20 < 0.6 : false
ext = is_nh and vr > 1.5 and cr > 0.6 ? 5.0 : pp > 85 and vr > 1.2 and cr > 0.5 ? 3.0 : de > 12 and vr > 2.0 and cr < 0.4 ? -8.0 : de > 8 and not isc and cr < 0.4 ? -5.0 : pp < 25 ? 3.0 : 0.0

// FINAL -- no multiplier, raw/38 x 100
raw = math.max(math.min(flow_score + accum_score + volume_score + skew_score + ext, 38), 0)
flow_100 = raw / 38.0 * 100.0

clr = flow_100 >= 84 ? color.lime : flow_100 >= 70 ? color.green : flow_100 >= 50 ? color.yellow : color.red
plot(flow_100, "Flow v1.3", color=clr, style=plot.style_histogram, linewidth=4)
hline(84, "Strong", color=color.green, linestyle=hline.style_dotted)
hline(70, "Qualified", color=color.yellow, linestyle=hline.style_dotted)
hline(50, "Watch", color=color.orange, linestyle=hline.style_dashed)
bgcolor(flow_100 >= 84 ? color.new(color.green,92) : flow_100 >= 70 ? color.new(color.yellow,95) : color.new(color.red,97))

var table t = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black,80))
if barstate.islast
    table.cell(t,0,0,"COMPONENT",bgcolor=color.blue,text_color=color.white,text_size=size.small)
    table.cell(t,1,0,"%MAX",bgcolor=color.blue,text_color=color.white,text_size=size.small)
    table.cell(t,0,1,"Flow(MFI+CMF+HA)",text_color=color.white,text_size=size.small)
    table.cell(t,1,1,str.tostring(flow_score/17*100,"#")+"%",text_color=flow_score/17*100>=75?color.lime:color.yellow,text_size=size.small)
    table.cell(t,0,2,"Accumulation",text_color=color.white,text_size=size.small)
    table.cell(t,1,2,str.tostring(accum_score/7.5*100,"#")+"%",text_color=accum_score/7.5*100>=70?color.lime:color.yellow,text_size=size.small)
    table.cell(t,0,3,"VolTrend",text_color=color.white,text_size=size.small)
    table.cell(t,1,3,str.tostring(volume_score/7.5*100,"#")+"%",text_color=volume_score/7.5*100>=60?color.lime:color.yellow,text_size=size.small)
    table.cell(t,0,4,"Vol Skew",text_color=color.white,text_size=size.small)
    table.cell(t,1,4,str.tostring(skew_score/3.5*100,"#")+"%",text_color=skew_score/3.5*100>=70?color.lime:color.yellow,text_size=size.small)
    table.cell(t,0,5,"Extension",text_color=color.white,text_size=size.small)
    table.cell(t,1,5,str.tostring(ext,"+#.#;-#.#"),text_color=ext>0?color.lime:ext<-3?color.red:color.orange,text_size=size.small)
    table.cell(t,0,6,"FLOW v1.3",bgcolor=clr,text_color=color.white,text_size=size.small)
    table.cell(t,1,6,str.tostring(flow_100,"#")+"/100",bgcolor=clr,text_color=color.white,text_size=size.small)

alertcondition(ta.crossover(flow_100, 84), "Flow Strong", "Flow >= 84")
alertcondition(ta.crossover(flow_100, 70), "Flow Qualified", "Flow >= 70")
