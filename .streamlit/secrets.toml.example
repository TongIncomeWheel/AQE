# Streamlit secrets template -- copy keys to the Streamlit Cloud UI under
# "Settings -> Secrets". DO NOT commit real values here; the actual secrets.toml
# is gitignored.
#
# AQE only needs FMP_API_KEY if you ever enable interactive scoring on the
# cloud deployment (currently disabled in cloud read-only mode).
#
# Pasted as-is into Streamlit Cloud's secret manager, this becomes available
# at runtime as `st.secrets["FMP_API_KEY"]`.

# FMP_API_KEY = "fmp_xxx"          # only if cloud-side fetching is re-enabled
# ANTHROPIC_API_KEY = "sk-ant-xxx" # only if AIC LLM features are re-enabled
