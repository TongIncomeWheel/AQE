# Streamlit secrets template -- copy these keys (with your real values) into
# Streamlit Cloud's secret manager:
#   https://share.streamlit.io  ->  your app  ->  Settings  ->  Secrets
#
# The cloud app reads these via `st.secrets[...]`. The bridge in
# streamlit_app.py mirrors FMP_API_KEY into os.environ before any AQE import,
# so the existing FMPClient (which reads os.environ) picks it up unchanged.
#
# DO NOT COMMIT real values. The actual secrets.toml file is gitignored.

# --- Required for the daily pipeline + ad-hoc scorer ----------------------
FMP_API_KEY = "fmp_xxx_your_real_key_here"

# --- Optional: only needed if you ever enable AIC LLM features on cloud ---
# ANTHROPIC_API_KEY = "sk-ant-xxx"
